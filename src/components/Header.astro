---
const phone = '(806) 450-8900';
const telLink = 'tel:+18064508900';
---

<header style="background-color: #1e3a8a;" class="text-white shadow-lg">
  <div class="max-w-6xl mx-auto px-4 py-4 flex flex-col sm:flex-row items-center justify-between gap-3">
    <a href="/" class="text-xl font-bold tracking-tight text-white hover:text-orange-200 transition-colors text-center sm:text-left">
      Lubbock Windshield Replacement
    </a>
    <a
      href={telLink}
      style="background-color: #dc2626;"
      class="text-white font-bold text-lg px-6 py-3 rounded-lg hover:brightness-110 transition-all shadow-md whitespace-nowrap"
    >
      Call Now: {phone}
    </a>
  </div>
  <nav style="background-color: #162d6e;" class="border-t border-blue-700">
    <div class="max-w-6xl mx-auto px-4 overflow-x-auto">
      <ul class="flex gap-1 py-2 text-sm whitespace-nowrap">
        <li><a href="/" class="px-3 py-1 rounded hover:bg-blue-700 transition-colors">Home</a></li>
        <li><a href="/services" class="px-3 py-1 rounded hover:bg-blue-700 transition-colors">Services</a></li>
        <li><a href="/windshield-replacement" class="px-3 py-1 rounded hover:bg-blue-700 transition-colors">Replacement</a></li>
        <li><a href="/windshield-chip-repair" class="px-3 py-1 rounded hover:bg-blue-700 transition-colors">Chip Repair</a></li>
        <li><a href="/mobile-service" class="px-3 py-1 rounded hover:bg-blue-700 transition-colors">Mobile Service</a></li>
        <li><a href="/insurance-claims" class="px-3 py-1 rounded hover:bg-blue-700 transition-colors">Insurance</a></li>
        <li><a href="/service-areas" class="px-3 py-1 rounded hover:bg-blue-700 transition-colors">Service Areas</a></li>
        <li><a href="/faq" class="px-3 py-1 rounded hover:bg-blue-700 transition-colors">FAQ</a></li>
        <li><a href="/about" class="px-3 py-1 rounded hover:bg-blue-700 transition-colors">About</a></li>
        <li><a href="/contact" class="px-3 py-1 rounded hover:bg-blue-700 transition-colors">Contact</a></li>
      </ul>
    </div>
  </nav>
</header>
