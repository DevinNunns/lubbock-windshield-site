---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CallButton from '../components/CallButton.astro';

const siteUrl = 'https://windshieldreplacementlubbock.com';
---

<Layout
  title="Auto Glass Services Lubbock TX | Windshield Repair"
  description="Full windshield replacement, chip repair, mobile service & insurance claims in Lubbock, TX. Call (806) 450-8900 for a free quote today."
  canonical={`${siteUrl}/services/`}
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type": "ListItem", "position": 1, "name": "Home", "item": `${siteUrl}/`},
      {"@type": "ListItem", "position": 2, "name": "Services", "item": `${siteUrl}/services/`}
    ]
  })} />
  <Header />

  <section style="background-color: #1e3a8a;" class="text-white py-12 px-4">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-3xl sm:text-4xl font-bold mb-3">Auto Glass Services in Lubbock, TX</h1>
      <p class="text-blue-200 text-lg max-w-2xl">Everything you need to get your windshield and auto glass back in perfect condition — fast, affordable, and backed by years of experience serving Lubbock drivers.</p>
    </div>
  </section>

  <main class="max-w-4xl mx-auto px-4 py-12">

    <div class="text-center mb-10">
      <CallButton label="Call for a Free Quote: (806) 450-8900" size="md" center={true} />
    </div>

    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-6" style="color: #1e3a8a;">What We Do</h2>
      <p class="text-gray-700 leading-relaxed mb-6">
        We offer a complete range of auto glass services for Lubbock residents and the surrounding West Texas communities. Whether you need a full windshield swap after a bad hailstorm, a quick chip repair before it spreads, or you want us to come to your location so you don't have to drive a damaged vehicle — we've got you covered.
      </p>

      <div class="space-y-8">

        <div class="border-l-4 pl-6" style="border-color: #1e3a8a;">
          <h3 class="text-xl font-bold mb-2" style="color: #1e3a8a;">Full Windshield Replacement</h3>
          <p class="text-gray-700 leading-relaxed mb-2">
            When a crack runs too long, splinters across your line of sight, or the structural integrity of the glass is compromised, a full replacement is the right call. We stock glass for a wide range of makes and models — domestic trucks and SUVs (very common in West Texas), sedans, and foreign vehicles. We use OEM-equivalent glass that meets or exceeds federal safety standards.
          </p>
          <p class="text-gray-700 leading-relaxed mb-3">
            Most standard replacements are done in 60 to 90 minutes. We'll give you a cure time recommendation before you drive off so the adhesive sets properly and your new windshield is fully sealed.
          </p>
          <a href="/windshield-replacement/" class="font-semibold hover:underline text-sm" style="color: #1e3a8a;">Learn more about windshield replacement &rarr;</a>
        </div>

        <div class="border-l-4 pl-6" style="border-color: #dc2626;">
          <h3 class="text-xl font-bold mb-2" style="color: #1e3a8a;">Windshield Chip &amp; Crack Repair</h3>
          <p class="text-gray-700 leading-relaxed mb-2">
            Small chips and short cracks can often be repaired without replacing the whole windshield — saving you money and preserving the original factory seal. This is especially valuable because most comprehensive insurance policies cover chip repair with zero deductible, meaning the fix costs you nothing out of pocket.
          </p>
          <p class="text-gray-700 leading-relaxed mb-3">
            We use a professional-grade resin injection process that restores structural integrity and clarity. Chips from gravel on Loop 289 or I-27, bullseye damage from hail — if it's smaller than a dollar bill, we can usually fix it without a full replacement.
          </p>
          <a href="/windshield-chip-repair/" class="font-semibold hover:underline text-sm" style="color: #1e3a8a;">Learn more about chip repair &rarr;</a>
        </div>

        <div class="border-l-4 pl-6" style="border-color: #1e3a8a;">
          <h3 class="text-xl font-bold mb-2" style="color: #1e3a8a;">Mobile Windshield Service</h3>
          <p class="text-gray-700 leading-relaxed mb-2">
            We bring the shop to you. Whether you're at home in the Tech Terrace neighborhood, parked at a job site near the airport, or sitting in a lot on 50th Street — we'll come to your location and handle the repair right there. No towing, no waiting at a shop, no rearranging your schedule.
          </p>
          <p class="text-gray-700 leading-relaxed mb-3">
            Mobile service covers all of Lubbock and most of the surrounding area including Wolfforth, Shallowater, Idalou, and more. Just call and we'll confirm we can reach you.
          </p>
          <a href="/mobile-service/" class="font-semibold hover:underline text-sm" style="color: #1e3a8a;">Learn more about mobile service &rarr;</a>
        </div>

        <div class="border-l-4 pl-6" style="border-color: #dc2626;">
          <h3 class="text-xl font-bold mb-2" style="color: #1e3a8a;">Insurance Claims Handling</h3>
          <p class="text-gray-700 leading-relaxed mb-2">
            Dealing with your insurance company after windshield damage can feel like a second job. We handle all of that for you. We'll contact your insurer, file the claim, and bill them directly. In many cases — especially for chip repairs — your deductible is waived entirely, and the service costs you nothing.
          </p>
          <p class="text-gray-700 leading-relaxed mb-3">
            We work with every major insurance carrier: State Farm, USAA, Allstate, Progressive, Geico, Farmers, Liberty Mutual, and more. If you have comprehensive coverage, your windshield damage is almost certainly covered.
          </p>
          <a href="/insurance-claims/" class="font-semibold hover:underline text-sm" style="color: #1e3a8a;">Learn more about insurance claims &rarr;</a>
        </div>

        <div class="border-l-4 pl-6" style="border-color: #1e3a8a;">
          <h3 class="text-xl font-bold mb-2" style="color: #1e3a8a;">ADAS Camera Recalibration</h3>
          <p class="text-gray-700 leading-relaxed mb-3">
            Many newer vehicles have cameras, sensors, and radar systems mounted to or behind the windshield — part of the Advanced Driver Assistance Systems (ADAS) that power features like lane departure warnings, automatic emergency braking, and adaptive cruise control. When the windshield is replaced, these systems need to be recalibrated to work correctly. We offer this service to make sure your safety systems are working as intended after any replacement.
          </p>
        </div>

      </div>
    </section>

    <section class="mb-12 bg-gray-50 rounded-xl p-8">
      <h2 class="text-2xl font-bold mb-4" style="color: #1e3a8a;">Vehicles We Service</h2>
      <p class="text-gray-700 leading-relaxed mb-4">
        We work on just about everything you'll find on Lubbock roads — and around here, that means a lot of pickups. We handle:
      </p>
      <ul class="grid grid-cols-2 sm:grid-cols-3 gap-2 text-gray-700 text-sm">
        <li class="flex gap-2"><span style="color: #dc2626;">&#10003;</span> Ford F-Series trucks</li>
        <li class="flex gap-2"><span style="color: #dc2626;">&#10003;</span> Chevy Silverado &amp; GMC Sierra</li>
        <li class="flex gap-2"><span style="color: #dc2626;">&#10003;</span> RAM 1500 / 2500 / 3500</li>
        <li class="flex gap-2"><span style="color: #dc2626;">&#10003;</span> Toyota Tacoma &amp; Tundra</li>
        <li class="flex gap-2"><span style="color: #dc2626;">&#10003;</span> SUVs and crossovers</li>
        <li class="flex gap-2"><span style="color: #dc2626;">&#10003;</span> Sedans and compacts</li>
        <li class="flex gap-2"><span style="color: #dc2626;">&#10003;</span> Minivans</li>
        <li class="flex gap-2"><span style="color: #dc2626;">&#10003;</span> Commercial vans</li>
        <li class="flex gap-2"><span style="color: #dc2626;">&#10003;</span> Work trucks</li>
      </ul>
    </section>

    <div class="text-center py-8 bg-blue-50 rounded-xl border border-blue-100">
      <h2 class="text-2xl font-bold mb-3" style="color: #1e3a8a;">Get a Free Quote Today</h2>
      <p class="text-gray-600 mb-5 max-w-xl mx-auto">Tell us your vehicle, describe the damage, and we'll give you an honest price — usually in under five minutes. Same-day service available across Lubbock.</p>
      <CallButton label="Call (806) 450-8900 Now" size="lg" center={true} />
    </div>

  </main>

  <Footer />
</Layout>
